<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CodingLab Dashboard</title>
    <!-- ប្រើប្រាស់ Boxicons Link ផ្លូវការដើម្បីឱ្យដូចរូបបង ១០០% -->
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            display: flex;
            background-color: #f5f6fa;
            min-height: 100vh;
        }

        /* --- Sidebar --- */
        .sidebar {
            width: 240px;
            background: #fff;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 24px 14px;
            position: fixed;
            height: 100vh;
            z-index: 100;
        }

        .logo-details {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 22px;
            font-weight: 700;
            color: #111;
            margin-bottom: 35px;
            padding-left: 8px;
        }

        .logo-cl {
            width: 38px;
            height: 38px;
            background-color: #5856d6;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 16px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .nav-links {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .nav-links li a {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: #707070; 
            font-size: 15px;
            font-weight: 400;
            padding: 10px 12px;
            border-radius: 8px;
            transition: all 0.2s ease;
        }

        .nav-links li a i {
            font-size: 22px;
            color: #707070;
        }

        /* Active State (Dahboard) */
        .nav-links li.active a {
            background: #eef3ff;
            color: #4070f4;
            font-weight: 500;
        }
        
        .nav-links li.active a i {
            color: #4070f4;
        }
        
        .nav-links li a:hover { color: #4070f4; }
        .nav-links li a:hover i { color: #4070f4; }

        .sidebar-footer {
            border-top: 1px solid #edf0f5;
            padding-top: 20px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .footer-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            color: #707070;
            font-weight: 400;
            padding: 4px 12px;
            font-size: 15px;
        }

        .footer-link {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: #707070;
        }
        
        .footer-link i {
            font-size: 22px;
            color: #707070;
        }

        /* Dark Mode Switch */
        .switch {
            position: relative;
            display: inline-block;
            width: 36px;
            height: 20px;
        }

        .switch input { opacity: 0; width: 0; height: 0; }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: #d1d1d6;
            transition: .3s;
            border-radius: 34px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 14px;
            width: 14px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .3s;
            border-radius: 50%;
        }

        input:checked + .slider { background-color: #4070f4; }
        input:checked + .slider:before { transform: translateX(16px); }

        /* --- Main Content --- */
        .main-content {
            margin-left: 240px;
            flex: 1;
            padding: 30px 40px;
            background: #f5f6fa;
            min-height: 100vh;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 35px;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 25px;
        }

        .header-left .menu-icon {
            cursor: pointer;
            display: flex;
            align-items: center;
        }
        
        .header-left .menu-icon i {
            font-size: 26px;
            color: #111;
        }

        .search-box {
            position: relative;
            width: 450px;
        }

        .search-box input {
            width: 100%;
            padding: 10px 15px 10px 45px;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            outline: none;
            font-size: 14px;
            background: #fff;
            color: #333;
        }

        .search-box i {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 20px;
            color: #707070;
        }

        .profile-img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
        }

        /* Title Sections */
        .section-title {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 24px;
            font-weight: 600;
            color: #111;
            margin-bottom: 25px;
        }

        .section-title .icon-bg {
            background-color: #1d4ed8;
            width: 34px;
            height: 34px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .section-title .icon-bg i {
            font-size: 20px;
            color: #fff;
        }

        /* Cards Grid */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
            margin-bottom: 35px;
        }

        .card {
            border-radius: 12px;
            padding: 32px 20px;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #111;
        }

        .card i {
            font-size: 32px;
            margin-bottom: 12px;
            color: #111;
        }

        .card .card-name {
            font-size: 15px;
            font-weight: 500;
            margin-bottom: 8px;
        }

        .card .card-value {
            font-size: 46px;
            font-weight: 600;
            letter-spacing: -0.5px;
            line-height: 1;
        }

        .card.likes { background-color: #4d96ff; }
        .card.comments { background-color: #ffe2ad; }
        .card.shares { background-color: #e4cdff; }

        /* Table Section */
        .table-container {
            width: 100%;
            margin-top: 15px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        th {
            padding: 12px 10px;
            font-size: 16px;
            font-weight: 600;
            color: #111;
        }

        td {
            padding: 18px 10px;
            font-size: 15px;
            color: #333;
            font-weight: 400;
            border-bottom: 1px solid #eef0f4;
        }

        tr:last-child td { border-bottom: none; }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <nav class="sidebar">
        <div>
            <div class="logo-details">
                <div class="logo-cl">CL</div>
                <span class="logo_name">CodingLab</span>
            </div>
            
            <ul class="nav-links">
                <li class="active">
                    <a href="#">
                        <!-- Dahboard Icon: រូបកុងទ័រឡាន (Speedometer) ដូចបេះបិទ -->
                        <i class='bx bx-tachometer'></i>
                        <span class="link-name">Dahboard</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <i class='bx bx-folder'></i>
                        <span class="link-name">Content</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <i class='bx bx-bar-chart-alt-2'></i>
                        <span class="link-name">Analytics</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <i class='bx bx-like'></i>
                        <span class="link-name">Like</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <!-- Comment Icon Sidebar: រូបប្រអប់សាររង្វង់មូលពីរជាន់ -->
                        <i class='bx bx-chat'></i>
                        <span class="link-name">Comment</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <!-- Share Icon Sidebar: រូបព្រួញបត់ទៅស្តាំ -->
                        <i class='bx bx-share'></i>
                        <span class="link-name">Share</span>
                    </a>
                </li>
            </ul>
        </div>
        
        <div class="sidebar-footer">
            <div class="footer-item">
                <a href="#" class="footer-link">
                    <!-- Logout Icon: រូបទ្វារមានព្រួញរត់ចេញទៅខាងស្តាំ -->
                    <i class='bx bx-log-out'></i>
                    <span>Logout</span>
                </a>
            </div>
            <div class="footer-item">
                <span class="footer-link">
                    <i class='bx bx-moon'></i>
                    <span>Dark Mode</span>
                </span>
                <label class="switch">
                    <input type="checkbox">
                    <span class="slider"></span>
                </label>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="main-content">
        <!-- Header -->
        <header>
            <div class="header-left">
                <div class="menu-icon">
                    <i class='bx bx-menu'></i>
                </div>
                <div class="search-box">
                    <i class='bx bx-search'></i>
                    <input type="text" placeholder="Search here...">
                </div>
            </div>
            <!-- Profile Image -->
            <img src="https://images.unsplash.com/photo-1539571696357-5a69c17a67c6?w=100&auto=format&fit=crop&q=60" alt="Profile" class="profile-img">
        </header>

        <!-- Dashboard Title -->
        <div class="section-title">
            <div class="icon-bg">
                <!-- រូបកុងទ័រឡានដូចខាងលើ -->
                <i class='bx bx-tachometer'></i>
            </div>
            <span>Dashboard</span>
        </div>

        <!-- Metric Cards -->
        <div class="cards-grid">
            <div class="card likes">
                <i class='bx bx-like'></i>
                <div class="card-name">Total Likes</div>
                <div class="card-value">50,120</div>
            </div>
            <div class="card comments">
                <!-- Comments Card Icon: រូបប្រអប់សាររង្វង់មូលពីរជាន់ (Chat Bubbles) -->
                <i class='bx bx-chat'></i>
                <div class="card-name">Comments</div>
                <div class="card-value">20,120</div>
            </div>
            <div class="card shares">
                <!-- Total Share Card Icon: រូបព្រួញបត់ទៅស្តាំ -->
                <i class='bx bx-share'></i>
                <div class="card-name">Total Share</div>
                <div class="card-value">10,120</div>
            </div>
        </div>

        <!-- Recent Activity Title -->
        <div class="section-title">
            <div class="icon-bg">
                <i class='bx bx-tachometer'></i>
            </div>
            <span>Recent Activity</span>
        </div>

        <!-- Table -->
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Joined</th>
                        <th>Type</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Prem Shahi</td>
                        <td>premshahi@gmail.com</td>
                        <td>2022-02-12</td>
                        <td>New</td>
                        <td>Liked</td>
                    </tr>
                    <tr>
                        <td>Deepa Chand</td>
                        <td>deepachand@gmail.com</td>
                        <td>2022-02-12</td>
                        <td>Member</td>
                        <td>Liked</td>
                    </tr>
                    <tr>
                        <td>Manisha Chand</td>
                        <td>prakashhai@gmail.com</td>
                        <td>2022-02-13</td>
                        <td>Member</td>
                        <td>Liked</td>
                    </tr>
                    <tr>
                        <td>Pratima Shahi</td>
                        <td>manishachand@gmail.com</td>
                        <td>2022-02-13</td>
                        <td>New</td>
                        <td>Liked</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>

</body>
</html>
